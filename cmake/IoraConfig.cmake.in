# IoraConfig.cmake.in - CMake package configuration file template

@PACKAGE_INIT@

# Find dependencies
include(CMakeFindDependencyMacro)

find_dependency(OpenSSL REQUIRED)
find_dependency(Threads REQUIRED)

# Include the exported targets
include("${CMAKE_CURRENT_LIST_DIR}/IoraTargets.cmake")

# Put iora_embed_assets() in scope for consumers (guarded so a partial/old
# install does not hard-fail — the function simply won't be defined).
if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/IoraEmbedAssets.cmake")
  include("${CMAKE_CURRENT_LIST_DIR}/IoraEmbedAssets.cmake")
endif()

# Check that all required components are available
check_required_components(Iora)